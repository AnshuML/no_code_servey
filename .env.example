# Copy to .env and fill values. Never commit .env.

# Environment: dev | prod (prod requires API keys)
SURVEY_ENVIRONMENT=dev

# Groq (https://console.groq.com/)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: office / VPN proxy for api.groq.com (HTTPS)
# Example: https://user:pass@proxy.company.com:8080
HTTPS_PROXY=

# HuggingFace (optional for private models)
HUGGINGFACE_TOKEN=
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# FAISS index storage (optional)
FAISS_INDEX_PATH=

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Local speech-to-text (optional). Install: pip install -e ".[voice]"
# SURVEY_WHISPER_MODEL=tiny
# SURVEY_WHISPER_DEVICE=cpu
# SURVEY_WHISPER_COMPUTE_TYPE=int8
# SURVEY_WHISPER_LANGUAGE=hi

# --- WhatsApp Cloud API (optional). Run: python -m survey_system.whatsapp_server
# Webhook URL (HTTPS) example: https://YOUR-NGROK.ngrok-free.app/webhook/whatsapp
# WHATSAPP_VERIFY_TOKEN=choose_a_random_string_you_type_in_meta_dashboard
# WHATSAPP_ACCESS_TOKEN=from_meta_graph_api
# WHATSAPP_PHONE_NUMBER_ID=from_meta_whatsapp_phone_number
# WHATSAPP_APP_SECRET=optional_for_X_Hub_Signature_256
# WHATSAPP_GRAPH_VERSION=v21.0
# Optional: custom survey JSON path (UTF-8). Empty = bundled family demo.
# WHATSAPP_SURVEY_JSON=
